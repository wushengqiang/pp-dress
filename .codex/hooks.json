{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash 'D:\\projects\\pp-dress\\.codex\\hooks\\validate-commit.sh'",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash 'D:\\projects\\pp-dress\\.codex\\hooks\\validate-push.sh'",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash 'D:\\projects\\pp-dress\\.codex\\hooks\\validate-assets.sh'",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash 'D:\\projects\\pp-dress\\.codex\\hooks\\validate-skill-change.sh'",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash 'D:\\projects\\pp-dress\\.codex\\hooks\\pre-compact.sh'",
            "timeout": 10
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash 'D:\\projects\\pp-dress\\.codex\\hooks\\post-compact.sh'",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash 'D:\\projects\\pp-dress\\.codex\\hooks\\session-start.sh'",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash 'D:\\projects\\pp-dress\\.codex\\hooks\\detect-gaps.sh'",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash 'D:\\projects\\pp-dress\\.codex\\hooks\\log-agent.sh'",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash 'D:\\projects\\pp-dress\\.codex\\hooks\\log-agent-stop.sh'",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash 'D:\\projects\\pp-dress\\.codex\\hooks\\session-stop.sh'",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
